# TokyoNight colors for dunst
# For more configuration options see https://github.com/dunst-project/dunst/blob/master/dunstrc

[global]
    corner_radius = 10
    font = CaskaydiaCove NF 13
    icon_theme = Papirus
    enable_recursive_icon_lookup = true
    icon_path = /usr/share/icons/Papirus/16x16/actions/:/usr/share/icons/hicolor/16x16/apps/:/usr/share/pixmaps/

[urgency_low]
    background = "#16161e"
    foreground = "#c0caf5"
    frame_color = "#c0caf5"

[urgency_normal]
    background = "#1a1b26"
    foreground = "#c0caf5"
    frame_color = "#c0caf5"

[urgency_critical]
    background = "#292e42"
    foreground = "#db4b4b"
    frame_color = "#db4b4b"
