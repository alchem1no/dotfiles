#!/bin/bash

symbol="${1:-$(cat)}"
[ -z "$symbol" ] && exit 0

prev=$(wl-paste --no-newline 2>/dev/null)

wl-copy "$symbol"

sleep 0.15 # Let launcher close + focus return before pasting
ydotool key 29:1 47:1 47:0 29:0 # Ctrl+V
sleep 0.5

if [ -n "$prev" ]; then
    printf "%s" "$prev" | wl-copy
else
    wl-copy --clear
fi

cliphist list | grep -F "$symbol" | head -1 | cliphist delete
