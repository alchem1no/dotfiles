[Unit]
Description=Google Drive (rclone)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/rclone mount gdrive: %h/gdrive --vfs-cache-mode full --vfs-cache-max-size 2G --log-level INFO
ExecStop=/usr/bin/fusermount3 -u %h/gdrive
Restart=on-failure

[Install]
WantedBy=default.target
